{
  "name": "daax-devtools",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Devcontainer and AI agents image tooling for Daax",
  "bin": {
    "daax-generate-tests": "src/generate-tests/cli.ts"
  },
  "scripts": {
    "agents:build": "docker build -t jpoley/daax-agents:latest devcontainer",
    "agents:push": "docker push jpoley/daax-agents:latest",
    "agents:release": "bun run agents:build && bun run agents:push",
    "generate-tests": "bun run src/generate-tests/cli.ts",
    "test": "bun test tests/",
    "test:integration": "DAAX_TC_INTEGRATION=1 bun test tests/integration.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@testcontainers/elasticsearch": "^10.13.0",
    "@testcontainers/postgresql": "^10.13.0",
    "@testcontainers/redis": "^10.13.0",
    "@types/node": "^22.5.0",
    "testcontainers": "^10.13.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
